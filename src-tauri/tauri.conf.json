{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ti-control",
  "version": "0.1.0",
  "identifier": "com.metalarc.ticontrol",
  "build": {
    "frontendDist": "../public/build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "TI Control - Gestión TIC",
        "width": 1280,
        "height": 720,
        "minWidth": 1024,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": null,
      "nsis": null
    }
  },
  "plugins": {
    "shell": {
      "scope": [
        {
          "name": "php",
          "cmd": "php",
          "args": true
        }
      ]
    }
  }
}
